<div class="projects-grid">
  {projects.map((p) => (
    <a class="project-card" href={`/projects/${p.slug}/`}>
      <div class="project-card-image">
        <img
          src={p.cover}
          alt={p.title}
          loading="lazy"
        />
      </div>

      <div class="project-card-meta">
        <h3>{p.title}</h3>
        <span>{p.year || p.project_id}</span>
      </div>
    </a>
  ))}
</div>