---
import projects from '../../data/projects.json';
export function getStaticPaths(){ return projects.map((p)=>({params:{slug:p.slug}, props:{project:p}})); }
const { project } = Astro.props;
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>{project.title} | SeenPleen Studio</title><style>body{margin:0;font-family:Arial,Helvetica,sans-serif;background:#f7f4ee;color:#111}header{padding:34px 6vw}a{color:#111}.intro{padding:40px 6vw}.intro h1{font-size:clamp(38px,7vw,88px);line-height:1;margin:0 0 18px}.meta{font-size:20px;color:#555}.desc{max-width:820px;font-size:19px;line-height:1.6}.gallery{columns:2 360px;column-gap:18px;padding:20px 6vw 80px}.gallery img{width:100%;margin:0 0 18px;break-inside:avoid;display:block}</style></head><body><header><a href="/">← SeenPleen Studio</a></header><section class="intro"><h1>{project.title}</h1><p class="meta">{project.project_id}</p><p class="desc">{project.details}</p></section><section class="gallery">{project.gallery.map((img)=>(<img src={img.url} alt={img.alt || project.title} loading="lazy"/>))}</section></body></html>