---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import projects from '../../data/projects.json';

export function getStaticPaths(){
  return projects.map((p, index)=>({
    params:{slug:p.slug},
    props:{
      project:p,
      previousProject: projects[index - 1] || projects[projects.length - 1],
      nextProject: projects[index + 1] || projects[0]
    }
  }));
}

const { project, previousProject, nextProject } = Astro.props;
const heroImage = project.cover || project.gallery?.[0]?.url;
---

<BaseLayout title={`${project.title} | SeenPleen Studio`}>
  <Header />

  <main class="project-page">
    {heroImage && (
      <section class="project-hero">
        <img src={heroImage} alt={project.title} />
      </section>
    )}

    <section class="project-intro">
      <div>
        <h1>{project.title}</h1>
      </div>

      <div class="project-info">
        <p class="project-meta">{project.project_id}</p>
        {project.details && <p>{project.details}</p>}
      </div>
    </section>

    <section class="project-gallery">
      {project.gallery.map((img)=>(
        <img
          src={img.url}
          alt={img.alt || project.title}
          loading="lazy"
        />
      ))}
    </section>

    <nav class="project-navigation">
      <a href={`/projects/${previousProject.slug}/`}>
        <span>Previous project</span>
        <strong>{previousProject.title}</strong>
      </a>

      <a href={`/projects/${nextProject.slug}/`}>
        <span>Next project</span>
        <strong>{nextProject.title}</strong>
      </a>
    </nav>
  </main>

  <Footer />
</BaseLayout>