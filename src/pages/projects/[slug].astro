---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import projects from '../../data/projects.json';

const visibleProjects = projects
  .filter((project) => !project.hidden)
  .sort((a, b) => {
    const orderA = Number.isInteger(a.order) ? a.order : Number.POSITIVE_INFINITY;
    const orderB = Number.isInteger(b.order) ? b.order : Number.POSITIVE_INFINITY;

    return orderA - orderB;
  });

export function getStaticPaths() {
  return visibleProjects.map((p, index) => ({
    params: { slug: p.slug },
    props: {
      project: p,
      previousProject: visibleProjects[index - 1] || visibleProjects[visibleProjects.length - 1],
      nextProject: visibleProjects[index + 1] || visibleProjects[0],
    },
  }));
}

const { project, previousProject, nextProject } = Astro.props;

const heroImage = project.hero || project.cover || project.gallery?.[0]?.url;
const gallery = project.gallery || [];

const detailParagraphs = project.details
  ? project.details.split('\n').filter((paragraph) => paragraph.trim().length > 0)
  : [];

const projectMeta = [
  { label: 'Category', value: project.category },
  { label: 'Subcategory', value: project.subcategory },
  { label: 'Client', value: project.client },
  { label: 'Location', value: project.location },
  { label: 'Year', value: project.year },
  { label: 'Area', value: project.area },
  { label: 'Status', value: project.status },
].filter((item) => item.value);
---

<BaseLayout title={`${project.title} | SeenPleen Studio`}>
  <Header />

  <main class="project-page">
    <section class="project-hero">
      {heroImage ? (
        <img
          src={heroImage}
          alt={project.title}
          loading="eager"
        />
      ) : (
        <div class="project-hero-placeholder"></div>
      )}
    </section>

    <section class="project-intro">
      <div class="project-title-block">
        <p class="project-kicker">Project</p>
        <h1>{project.title}</h1>
      </div>

      <div class="project-info">
        {project.project_id && (
          <p class="project-meta-line">{project.project_id}</p>
        )}

        {projectMeta.length > 0 && (
          <dl class="project-meta-list">
            {projectMeta.map((item) => (
              <div class="project-meta-item">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        )}

        {detailParagraphs.length > 0 ? (
          <div class="project-description">
            {detailParagraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        ) : (
          <div class="project-description">
            <p>Project information will be added soon.</p>
          </div>
        )}
      </div>
    </section>

    {gallery.length > 0 && (
      <section class="project-gallery">
        {gallery.map((img, index) => (
          <figure class={`project-gallery-item project-gallery-item-${(index % 6) + 1}`}>
            <img
              src={img.url}
              alt={img.alt || project.title}
              loading={index < 2 ? 'eager' : 'lazy'}
            />
          </figure>
        ))}
      </section>
    )}

    <nav class="project-navigation" aria-label="Project navigation">
      <a href={`/projects/${previousProject.slug}/`}>
        <span>Previous Project</span>
        <strong>{previousProject.title}</strong>
      </a>

      <a href={`/projects/${nextProject.slug}/`}>
        <span>Next Project</span>
        <strong>{nextProject.title}</strong>
      </a>
    </nav>
  </main>

  <Footer />
</BaseLayout>