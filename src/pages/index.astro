---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import projects from '../data/projects.json';
---

<BaseLayout title="SeenPleen Studio">
  <Header />

  <section class="home-hero">
    <img
      src="/images/the-matchbox-house/1.jpg"
      alt="The Matchbox House"
      class="home-hero-image"
      loading="eager"
    />

    <div class="home-hero-overlay">
      <p class="home-hero-kicker">
        Architecture / Interior Design / Visualization
      </p>

      <h1>SeenPleen Studio</h1>

      <a href="/projects/the-matchbox-house/" class="home-hero-link">
        The Matchbox House
      </a>
    </div>
  </section>

  <section class="projects-section" id="projects">
    <div class="projects-heading">
      <span>Selected Works</span>
      <h2>Projects</h2>
    </div>

    <div class="projects-grid">
      {projects.map((p, index) => (
        <a class="project-card" href={`/projects/${p.slug}/`}>
          <div class="project-card-image">
            {p.cover ? (
              <img
                src={p.cover}
                alt={p.title}
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            ) : (
              <div class="project-card-placeholder"></div>
            )}

            <div class="project-card-hover">
              <h3>{p.title}</h3>
              <p>{p.project_id}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</BaseLayout>