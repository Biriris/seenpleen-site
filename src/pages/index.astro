---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import projects from '../data/projects.json';
---

<BaseLayout title="SeenPleen Studio | Konstantinos Kostaras">
  <Header />

  <section class="hero">
    <h1>SeenPleen Studio</h1>

    <p class="hero-tagline">
      Architecture, Interior Design & Visualization
    </p>

    <p class="hero-subtitle">
      Selected residential, hospitality and commercial projects by
      Konstantinos Kostaras.
    </p>
  </section>

  <h2 class="section-title" id="projects">
    Projects
  </h2>

  <main class="grid">
    {projects.map((p) => (
      <a class="card" href={`/projects/${p.slug}/`}>
        {p.cover && (
          <img src={p.cover} alt={p.title} loading="lazy" />
        )}

        <div>
          <h2>{p.title}</h2>
          <p>{p.project_id}</p>
        </div>
      </a>
    ))}
  </main>

  <Footer />
</BaseLayout>