---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import projects from '../data/projects.json';

const featuredProject =
  projects.find((project) => project.featured) ||
  projects.find((project) => project.slug === 'the-matchbox-house') ||
  projects[0];

const featuredImage = featuredProject?.hero || featuredProject?.cover;
---

<BaseLayout title="SeenPleen Studio">
  <Header />

  {featuredProject && featuredImage && (
    <section class="home-hero">
      <img
        src={featuredImage}
        alt={featuredProject.title}
        class="home-hero-image"
        loading="eager"
      />

      <div class="home-hero-overlay">
        <a href={`/projects/${featuredProject.slug}/`} class="home-hero-link">
          {featuredProject.title}
        </a>
      </div>
    </section>
  )}

  <section class="projects-section" id="projects">
    <div class="projects-heading">
      <span>Selected Works</span>
      <h2>Projects</h2>
    </div>

    <div class="projects-grid">
      {projects.map((p, index) => {
        const hoverMeta = [
          p.category,
          p.subcategory,
          p.location,
          p.year,
        ].filter(Boolean);

        return (
          <a class="project-card" href={`/projects/${p.slug}/`}>
            <div class="project-card-image">
              {p.cover ? (
                <img
                  src={p.cover}
                  alt={p.title}
                  loading={index === 0 ? 'eager' : 'lazy'}
                />
              ) : (
                <div class="project-card-placeholder"></div>
              )}

              <div class="project-card-hover">
                <div class="project-card-hover-inner">
                  <h3>{p.title}</h3>

                  {hoverMeta.length > 0 && (
                    <p>{hoverMeta.join(' / ')}</p>
                  )}
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <Footer />
</BaseLayout>