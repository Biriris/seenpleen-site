---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import projects from '../data/projects.json';
---

<BaseLayout title="SeenPleen Studio | Konstantinos Kostaras">
  <Header />

  <section class="home-hero">
  <img
    src="/images/the-matchbox-house/1.jpg"
    alt="The Matchbox House"
    class="home-hero-image"
    loading="eager"
  />

  <div class="home-hero-overlay">
    <p class="home-hero-kicker">Architecture / Interior Design / Visualization</p>

    <h1>SeenPleen Studio</h1>

    <a href="/projects/the-matchbox-house/" class="home-hero-link">
      The Matchbox House
    </a>
  </div>
</section>

  <h2 class="section-title" id="projects">
    Projects
  </h2>

  <main class="grid">
    {projects.map((p) => (
      <a class="card" href={`/projects/${p.slug}/`}>
        {p.cover && (
          <img src={p.cover} alt={p.title} loading="lazy" />
        )}

        <div>
          <h2>{p.title}</h2>
          <p>{p.project_id}</p>
        </div>
      </a>
    ))}
  </main>

  <Footer />
</BaseLayout>